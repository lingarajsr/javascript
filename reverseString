<!DOCTYPE html>
<html>
<head>
    <title>Reverse String</title>
</head>
<body>

<script>
function reverseString(str) {
    return str.split("").reverse().join("");
}

console.log(reverseString("hello"));
console.log(reverseString("JavaScript"));
console.log(reverseString("12345"));
</script>

</body>
</html>
